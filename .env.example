# Bu dosyayı ".env" olarak kopyalayıp gerçek değerlerle doldurun.
# .env dosyası gitignore'dadır; ASLA commit etmeyin.

# PostgreSQL bağlantı dizesi (Neon / Vercel Postgres).
# Neon panelinden "Connection string" (pooled) alıp buraya yapıştırın.
# Örnek: postgresql://kullanici:sifre@ep-xxx.eu-central-1.aws.neon.tech/dbadi?sslmode=require
DATABASE_URL="postgresql://kullanici:sifre@host:5432/dbadi?sslmode=require"
